# Create an untracked .env from this template before any real API call.
# Never commit .env or paste real provider keys into tracked docs or outputs.
# Current primary path: DeepSeek official API.
DEEPSEEK_API_KEY=<your-deepseek-key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
PRIMARY_MODEL=deepseek-v4-pro

# Optional alternative path: OpenRouter.
OPENROUTER_API_KEY=<your-openrouter-key>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=120
OPENROUTER_MAX_RETRIES=2
OPENROUTER_RETRY_BACKOFF_SECONDS=2
PRIMARY_MODEL=deepseek-v4-pro
